# ==============================================================================
# ENVIRONMENT VARIABLES FOR LEARNING LABS (EXAMPLE)
# ==============================================================================

# AWS Configuration (Digunakan oleh Terraform AWS / sample7)
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
AWS_DEFAULT_REGION="us-east-1"
AWS_PROFILE="default"

# Google Cloud Platform (GCP) Configuration (Digunakan oleh Terraform GCP / exercise3)
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your-gcp-service-account-key.json"
GCP_PROJECT="your-gcp-project-id"
GCP_REGION="europe-west1"
GCP_ZONE="europe-west1-b"

# Ansible Inventory Configuration
WEB1_IP="192.168.1.10"
WEB1_USER="ubuntu"
WEB2_IP="192.168.1.11"
WEB2_USER="ubuntu"
